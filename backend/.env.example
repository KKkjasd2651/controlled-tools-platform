# ===== 文件服务器 =====
# SBPC 现场：每个工令在 <FILE_SERVER_ROOT>/<工令号>/ 下平铺存放
#   - 文件清单.xlsx        (DML，由 TDML 模板复制)
#   - <原文件名>            (受控文件本体，加水印+加密后落盘)
# 生产路径示例：FILE_SERVER_ROOT=\\sbpc-dc.com\sbpc\项目\ceshi
# 本地演示路径：FILE_SERVER_ROOT=./fileserver
FILE_SERVER_ROOT=\\sbpc-dc.com\sbpc\项目\ceshi
DML_TEMPLATE=./templates/DML_template.xlsx
DML_FILENAME=文件清单.xlsx
# CONTROLLED_DIR 留空 = 文件平铺在 <工令号>/ 根下（SBPC 约定）；填值则放子目录
CONTROLLED_DIR=
# 启动期对 FILE_SERVER_ROOT 做可写性自检；失败拒启服务。开发可改 false
REQUIRE_WRITABLE_FS=true

# ===== 文件名正则（备用，当前流程不做强制校验）=====
FILENAME_REGEX=^(?P<code>(?P<project>[A-Za-z0-9]+)-[A-Za-z]{2}-[A-Za-z]{2}-[A-Za-z0-9]+)_V(?P<version>\d+(?:\.\d+)*)\s+(?P<title>.+)\.(?P<ext>pdf|PDF|docx|DOCX|xlsx|XLSX|dwg|DWG)$

# ===== PDF 印章 / 加密 =====
# 上传时 PDF 每页右下角打蓝色圆角印章：大字 = WATERMARK_TEXT，小字 = "By <用户名> at <时间>"
# 加密策略：
#   - PDF_USER_PASSWORD 空 = 任何人都能"打开查看"（不输口令）
#   - PDF_OWNER_PASSWORD = 强口令，只有它才能解除"禁止编辑/复制/注释"的限制
# ⚠ owner_password 必须保密。请生成 32+ 字符随机串替换默认值：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
PDF_OWNER_PASSWORD=changeit-please-replace-with-32-char-random-string
PDF_USER_PASSWORD=
WATERMARK_TEXT=CONTROLLED

# ===== 应用 =====
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# ===== Seatable - 暂未启用 (要启用时去掉下面 4 行的 # 并填真实值，同时取消 main.py 里 Seatable 段的注释) =====
# SEATABLE_SERVER_URL=https://cloud.seatable.io
# SEATABLE_API_TOKEN=<your-seatable-api-token>
# SEATABLE_TABLE_NAME=钣金件清单

